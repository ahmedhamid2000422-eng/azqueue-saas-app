# AzQueue · environment template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env or .env.local — they are gitignored on purpose.
#
# These variables are exposed to the CLIENT (browser bundle).
# Anything VITE_-prefixed is intentionally public.
# Anything sensitive (Stripe SECRET, Twilio TOKEN, Anthropic key,
# Supabase SERVICE_ROLE) belongs in Supabase Edge Function SECRETS —
# set them with `supabase secrets set …`.

# ── Supabase ─────────────────────────────────────────────────
# Project URL — public, safe in the client.
VITE_SUPABASE_URL=https://YOURPROJECT.supabase.co

# Anon key — public BY DESIGN. RLS enforces row-level security at the DB.
# This is NOT the service role key. Do NOT put the service role key here.
VITE_SUPABASE_ANON_KEY=eyJ...

# ── Optional public values ───────────────────────────────────
# Stripe publishable key (pk_test_… or pk_live_…) if you embed Elements directly.
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_…

# ── Server-only secrets (NEVER in this file) ─────────────────
# Set these in Supabase Dashboard → Project Settings → Edge Functions → Secrets,
# or via the CLI:
#
#   supabase secrets set STRIPE_SECRET_KEY=sk_live_…
#   supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_…
#   supabase secrets set STRIPE_PRICE_ESSENTIAL=price_…
#   supabase secrets set STRIPE_PRICE_PROFESSIONAL=price_…
#   supabase secrets set STRIPE_PRICE_EXECUTIVE=price_…
#   supabase secrets set STRIPE_PRICE_MANAGER=price_…
#   supabase secrets set TWILIO_ACCOUNT_SID=AC…
#   supabase secrets set TWILIO_AUTH_TOKEN=…
#   supabase secrets set TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-…
#   supabase secrets set APP_URL=https://azqueue.app
#
# Supabase auto-injects SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY into every
# edge function — you don't need to set those.
