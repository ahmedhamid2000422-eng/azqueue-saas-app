# ── Supabase ─────────────────────────────────────────────────────────
# Copy from Supabase → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # ⚠ Never expose to frontend

# ── Server ────────────────────────────────────────────────────────────
PORT=3001

# Comma-separated list of allowed CORS origins (your frontend URL)
CORS_ORIGINS=http://localhost:5173,https://azqueue.com

# Shared secret — add to x-api-key header on every request from your app
# Leave empty to disable auth (dev only)
CHANNEL_API_KEY=your-random-secret-here

# ── LLM (enrichment only) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Override model (default: claude-haiku-4-5-20251001 — fast + cheap)
# ENRICH_MODEL=claude-sonnet-4-6

# Cache TTL in hours (default: 24)
# ENRICH_CACHE_HOURS=24

# ── Channel webhooks ──────────────────────────────────────────────────
# Meta (Facebook + Instagram + WhatsApp)
META_VERIFY_TOKEN=your-webhook-verify-token       # set in Meta Developer Console
META_APP_SECRET=your-meta-app-secret              # for signature verification

# ── Zid (e-commerce OAuth) ────────────────────────────────────────────
# Register an app at https://partner.zid.sa to get these two values.
# This is an account-level step only the store owner/business can do —
# nothing in this codebase can create that Partner Dashboard app for you.
ZID_CLIENT_ID=your-zid-app-client-id
ZID_CLIENT_SECRET=your-zid-app-client-secret      # ⚠ Never expose to frontend

# Must exactly match a redirect URL registered for your app in the
# Partner Dashboard, and must be a public HTTPS URL this server can
# actually receive requests on (so wherever channel-api ends up deployed).
ZID_REDIRECT_URI=https://your-channel-api-domain.com/zid/callback

# Where to send the merchant's browser back to after connecting/declining.
# Should be the AzQueue frontend's own URL.
FRONTEND_URL=http://localhost:5173
